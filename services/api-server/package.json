{
  "name": "@toppers/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx ./src/tests/run.ts"
  },
  "dependencies": {
    "@toppers/auth": "workspace:*",
    "@toppers/db": "workspace:*",
    "@toppers/validations": "workspace:*",
