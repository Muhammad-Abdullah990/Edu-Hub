NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

DB_USER=toppers
DB_PASSWORD=changeme
DB_NAME=toppers_db
DB_PORT=5439
DATABASE_URL=postgres://toppers:changeme@127.0.0.1:5439/toppers_db
VITE_API_PROXY_TARGET=http://127.0.0.1:3001

REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

JWT_ACCESS_SECRET=dev-secret-key-must-be-at-least-32-chars-long-xxx
JWT_REFRESH_SECRET=dev-refresh-secret-must-be-at-least-32-chars-xxx
JWT_ACCESS_EXPIRY=24h
JWT_REFRESH_EXPIRY=30d

CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://127.0.0.1:*
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

WHATSAPP_PHONE=923263987552
WHATSAPP_API_URL=https://api.whatsapp.com

PDF_TIMEOUT=30000
PDF_FORMAT=A4

AUTOMATION_LOG_DIR=./storage/logs
AUTOMATION_REPORT_DIR=./storage/reports

ENABLE_ANALYTICS=true
ENABLE_AUTOMATION=true
ENABLE_AI_FEATURES=false
ENABLE_EMAIL_NOTIFICATIONS=false
