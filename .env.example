# ============================================================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================================
# Copy this file to .env.development, .env.staging, or .env.production
# and update values as needed.
#
# DO NOT commit actual secrets to version control!
# ============================================================================

# Node Environment
NODE_ENV=development

# Server
PORT=3000
LOG_LEVEL=info

# Database
DB_USER=toppers
DB_PASSWORD=changeme
DB_NAME=toppers_db
DB_PORT=5439
DATABASE_URL=postgres://toppers:changeme@127.0.0.1:5439/toppers_db

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# JWT Secrets (minimum 32 characters)
JWT_ACCESS_SECRET=your-secret-key-must-be-at-least-32-characters-long
JWT_REFRESH_SECRET=your-refresh-secret-must-be-at-least-32-characters-long
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

# Security
CORS_ORIGIN=http://localhost:3001,http://localhost:3002
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# WhatsApp Integration
WHATSAPP_PHONE=923263987552
WHATSAPP_API_URL=https://api.whatsapp.com

# PDF Generation
PDF_TIMEOUT=30000
PDF_FORMAT=A4

# Automation Agent
AUTOMATION_LOG_DIR=/app/storage/logs
AUTOMATION_REPORT_DIR=/app/storage/reports

# Email (future)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Analytics
ANALYTICS_CACHE_TTL=3600

# AI Integration (future)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# Monitoring (future)
SENTRY_DSN=
DATADOG_API_KEY=

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_AUTOMATION=true
ENABLE_AI_FEATURES=false
ENABLE_EMAIL_NOTIFICATIONS=false
